{
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Read(~/dev/doc/*)",
      "Edit(~/dev/doc/*)",
      "Bash(mkdir:~/dev/doc*)",
      "Bash(ls:~/dev/doc*)",
      "Bash(git commit *)",
      "Read(~/dev/seqix/*)",
      "Read(~/dev/chess-counter/*)"
    ]
  },
  "model": "sonnet",
  "statusLine": {
    "type": "command",
    "command": "~/dotfiles/claude/statusline.sh"
  },
  "theme": "dark",
  "agentPushNotifEnabled": true
}
